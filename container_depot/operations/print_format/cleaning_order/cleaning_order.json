{
 "custom_format": 1,
 "doc_type": "Cleaning Order",
 "doctype": "Print Format",
 "html": "{%- set c = frappe.get_doc(\"Container\", doc.container) if doc.container else {} -%}\n<div class=\"iso-clean-stmt\" style=\"font-family: Arial, sans-serif; color: #1a1a1a; max-width: 760px; margin: auto; font-size: 12px;\">\n\n\t<div style=\"text-align: center; border-bottom: 2px solid #333; padding-bottom: 8px; margin-bottom: 12px;\">\n\t\t<img src=\"{{ get_logo_pdf() }}\" alt=\"OAK Depot\" style=\"max-height: 60px; object-fit: contain; margin-bottom: 4px;\">\n\t\t<h2 style=\"margin: 4px 0 0 0; letter-spacing: 1px;\">ISO TANK CLEANLINESS STATEMENT</h2>\n\t</div>\n\n\t<table style=\"width: 100%; border-collapse: collapse; margin-bottom: 10px;\">\n\t\t<tr>\n\t\t\t<td style=\"padding: 2px 6px;\"><strong>Order No:</strong> {{ doc.order_id or doc.name }}</td>\n\t\t\t<td style=\"padding: 2px 6px;\"><strong>Date of Issue:</strong> {{ frappe.format(doc.date_of_issue, {\"fieldtype\": \"Date\"}) or \"\" }}</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td style=\"padding: 2px 6px;\"><strong>Tank No:</strong> {{ doc.container_no or doc.container }}</td>\n\t\t\t<td style=\"padding: 2px 6px;\"><strong>Place of Issue:</strong> {{ doc.place_of_issue or \"\" }}</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td style=\"padding: 2px 6px;\"><strong>Reference EIR:</strong> {{ doc.inspection or \"—\" }}</td>\n\t\t\t<td style=\"padding: 2px 6px;\"><strong>Client / Principal:</strong> {{ c.principal or \"—\" }}</td>\n\t\t</tr>\n\t</table>\n\n\t<table style=\"width: 100%; border-collapse: collapse; border: 1px solid #999; margin-bottom: 12px; font-size: 11px;\">\n\t\t<tr>\n\t\t\t<td style=\"border: 1px solid #ccc; padding: 4px 6px;\"><strong>Tank Type:</strong> {{ c.container_type or \"—\" }}</td>\n\t\t\t<td style=\"border: 1px solid #ccc; padding: 4px 6px;\"><strong>Date of Mfg:</strong> {{ frappe.format(c.manufacture_date, {\"fieldtype\": \"Date\"}) or \"—\" }}</td>\n\t\t\t<td style=\"border: 1px solid #ccc; padding: 4px 6px;\"><strong>Last Test:</strong> {{ frappe.format(c.last_test_date, {\"fieldtype\": \"Date\"}) or \"—\" }}</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td style=\"border: 1px solid #ccc; padding: 4px 6px;\"><strong>Tare (kg):</strong> {{ c.tare_weight or \"—\" }}</td>\n\t\t\t<td style=\"border: 1px solid #ccc; padding: 4px 6px;\"><strong>MGW (kg):</strong> {{ c.max_gross_weight or \"—\" }}</td>\n\t\t\t<td style=\"border: 1px solid #ccc; padding: 4px 6px;\"><strong>Capacity (L):</strong> {{ c.capacity or \"—\" }}</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td style=\"border: 1px solid #ccc; padding: 4px 6px;\" colspan=\"2\"><strong>Previous Cargo:</strong> {{ c.last_cargo or \"—\" }}</td>\n\t\t</tr>\n\t</table>\n\n\t\n\t\n\t\n\t<table style=\"width: 100%; border-collapse: collapse; border: 1px solid #333; margin-bottom: 12px;\">\n\t\t<thead>\n\t\t\t<tr style=\"background: #f0f0f0;\">\n\t\t\t\t<th style=\"border: 1px solid #333; padding: 5px; text-align: left; width: 54%;\">Service</th>\n\t\t\t\t<th style=\"border: 1px solid #333; padding: 5px; width: 23%;\">Tarif</th>\n\t\t\t\t<th style=\"border: 1px solid #333; padding: 5px; width: 23%;\">Manhour (jam)</th>\n\t\t\t</tr>\n\t\t</thead>\n\t\t<tbody>\n\t\t\t{%- for r in doc.cleaning_services -%}\n\t\t\t<tr>\n\t\t\t\t<td style=\"border: 1px solid #ccc; padding: 4px 6px;\">{{ r.item_name or r.cleaning_item }}</td>\n\t\t\t\t<td style=\"border: 1px solid #ccc; padding: 4px 6px; text-align: right;\">{{ frappe.format_value(r.rate, {\"fieldtype\": \"Currency\", \"options\": \"currency\"}, doc) }}</td>\n\t\t\t\t<td style=\"border: 1px solid #ccc; padding: 4px 6px; text-align: right;\">{{ r.manhour_rate or 0 }}</td>\n\t\t\t</tr>\n\t\t\t{%- endfor -%}\n\t\t\t<tr>\n\t\t\t\t<td colspan=\"2\" style=\"border: 1px solid #333; padding: 4px 6px; text-align: right;\"><strong>Total Tarif Service</strong></td>\n\t\t\t\t<td style=\"border: 1px solid #333; padding: 4px 6px; text-align: right;\">{{ frappe.format_value(doc.cleaning_total, {\"fieldtype\": \"Currency\", \"options\": \"currency\"}, doc) }}</td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<td colspan=\"2\" style=\"border: 1px solid #333; padding: 4px 6px; text-align: right;\"><strong>Total Manhour (jam)</strong></td>\n\t\t\t\t<td style=\"border: 1px solid #333; padding: 4px 6px; text-align: right;\">{{ doc.manhour_total or 0 }}</td>\n\t\t\t</tr>\n\t\t\t/tbody>\n\t</table>\n\n\t{%- if doc.remarks %}\n\t<div style=\"border: 1px solid #999; padding: 6px 8px; margin-bottom: 24px; white-space: pre-line;\"><strong>Remarks:</strong><br>{{ doc.remarks }}</div>\n\t{%- endif %}\n\n\t<div style=\"display: flex; justify-content: space-between; margin-top: 40px;\">\n\t\t<div style=\"width: 250px; text-align: center;\">\n\t\t\t<div style=\"border-bottom: 1px solid #999; height: 50px;\"></div>\n\t\t\t<p style=\"margin-top: 4px;\">Customer Representative</p>\n\t\t</div>\n\t\t<div style=\"width: 250px; text-align: center;\">\n\t\t\t{%- if doc.surveyor_signature %}\n\t\t\t<img src=\"{{ doc.surveyor_signature }}\" style=\"max-height: 48px; object-fit: contain;\">\n\t\t\t{%- else %}\n\t\t\t<div style=\"height: 50px;\"></div>\n\t\t\t{%- endif %}\n\t\t\t<div style=\"border-bottom: 1px solid #999;\"></div>\n\t\t\t<p style=\"margin-top: 4px;\">Surveyor — {{ doc.signed_by or \"\" }}</p>\n\t\t</div>\n\t</div>\n</div>\n",
 "module": "Operations",
 "name": "Cleaning Order Format",
 "print_format_type": "Jinja Template",
 "standard": "Yes",
 "modified": "2026-07-23 22:00:00.000000"
}
