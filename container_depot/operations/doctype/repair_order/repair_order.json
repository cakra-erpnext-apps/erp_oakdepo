      "fieldtype": "Table",
      "label": "Estimation Items (legacy)",
      "options": "Repair Estimate Item"
    },
    {
      "fieldname": "cost_section",
      "fieldtype": "Section Break",
      "label": "Cost & Billing"
    },
    {
      "fieldname": "total_cost",
      "fieldtype": "Int",
      "label": "Total Cost",
      "read_only": 1
    },
    {
      "default": "Unbilled",
      "fieldname": "billing_status",
      "fieldtype": "Select",
      "label": "Billing Status",
      "options": "Unbilled\nClient Billed\nPrincipal Billed\nCompleted",
      "reqd": 1
    },
    {
      "fieldname": "remarks",
      "fieldtype": "Small Text",
      "label": "Remarks"
    },
    {
