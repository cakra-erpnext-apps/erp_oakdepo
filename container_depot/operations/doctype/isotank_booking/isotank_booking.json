  "fields": [
    {
      "fieldname": "header_section",
      "fieldtype": "Section Break",
      "label": "Booking"
    },
    {
      "fieldname": "direction",
      "fieldtype": "Select",
      "in_list_view": 1,
      "in_standard_filter": 1,
      "label": "Direction",
      "options": "Tank In\nTank Out",
      "reqd": 1
    },
    {
      "description": "Auto-derived from Direction (billing/crane view): Tank In = Lift Off (drop at depot), Tank Out = Lift On (take from depot).",
      "fieldname": "lift_type",
      "fieldtype": "Select",
      "label": "Lift Type",
      "options": "\nLift On\nLift Off",
      "read_only": 1
    },
    {
      "default": "Pending Payment",
      "fieldname": "booking_status",
      "fieldtype": "Select",
      "in_list_view": 1,
      "in_standard_filter": 1,
      "label": "Booking Status",
      "options": "Pending Payment\nPending Confirmation\nConfirmed\nIn Progress\nCompleted\nCancelled\nBlocked",
      "reqd": 1
    },
    {
      "fieldname": "column_break_1",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "customer",
      "fieldtype": "Link",
      "in_list_view": 1,
      "in_standard_filter": 1,
      "label": "Customer",
      "options": "Customer",
      "reqd": 1
    },
    {
      "fieldname": "depot",
      "fieldtype": "Link",
      "in_standard_filter": 1,
      "label": "Depot",
      "options": "Depot",
      "reqd": 1
    },
    {
      "description": "Optional. Leave empty for a walk-in Cash booking (no standing contract); the Cashier marks the Sales Invoice Paid to release the booking code.",
      "fieldname": "contract",
      "fieldtype": "Link",
      "label": "Contract",
      "options": "Depot Contract"
    },
    {
      "fetch_from": "contract.payment_type",
      "fieldname": "payment_type",
      "fieldtype": "Data",
      "label": "Payment Type",
      "read_only": 1
    },
    {
      "fieldname": "ownership_section",
      "fieldtype": "Section Break",
      "label": "Ownership & Delivery Order"
    },
    {
      "description": "COC = Carrier Owned Container (shipping line owns); SOC = Shipper Owned Container (tank principal owns).",
      "fieldname": "ownership",
      "fieldtype": "Select",
      "label": "Ownership",
      "options": "\nCOC\nSOC"
    },
    {
      "depends_on": "eval:doc.ownership=='COC'",
      "fieldname": "shipping_line",
      "fieldtype": "Link",
      "label": "Shipping Line",
      "options": "Shipping Line"
    },
    {
      "depends_on": "eval:doc.ownership=='SOC'",
      "fieldname": "tank_principal",
      "fieldtype": "Link",
      "label": "Tank Principal",
      "options": "Customer"
    },
    {
      "fieldname": "column_break_own",
      "fieldtype": "Column Break"
    },
    {
      "description": "Delivery Order reference — required before Submit to confirm the booking (both Lift On and Lift Off). A draft may be saved without it.",
      "fieldname": "do_reference",
      "fieldtype": "Data",
      "label": "DO Reference",
      "mandatory_depends_on": "eval:doc.docstatus==1"
    },
    {
      "description": "Scan/PDF of the Delivery Order. Optional — may be attached later.",
      "fieldname": "do_document",
      "fieldtype": "Attach",
      "label": "DO Document"
    },
    {
      "fieldname": "commercial_section",
      "fieldtype": "Section Break",
      "label": "Commercial"
    },
    {
      "fieldname": "job_reference_no",
      "fieldtype": "Data",
      "label": "Job Reference No"
    },
    {
      "fieldname": "agent",
      "fieldtype": "Data",
      "label": "Agent"
    },
    {
      "fieldname": "column_break_2",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "sales_invoice",
      "fieldtype": "Link",
      "label": "Sales Invoice",
      "options": "Sales Invoice"
    },
    {
      "default": "Unpaid",
      "description": "TOP bookings accrue 'Unpaid' until the depot runs consolidated billing (then 'Invoiced'). Cash bookings are 'Paid' at submit.",
      "fieldname": "payment_status",
      "fieldtype": "Select",
      "in_list_view": 1,
      "in_standard_filter": 1,
      "label": "Payment Status",
      "options": "Unpaid\nInvoiced\nPaid",
      "read_only": 1
    },
    {
      "fieldname": "block_reason",
      "fieldtype": "Small Text",
      "label": "Block Reason",
      "read_only": 1
    },
    {
      "fieldname": "items_section",
      "fieldtype": "Section Break",
      "label": "Items"
    },
    {
      "fieldname": "items",
      "fieldtype": "Table",
      "label": "Items",
      "options": "Isotank Booking Item",
      "reqd": 1
    }
  ],
